# Секретные файлы с паролями и ключами
.env_sql
.env_push

# Остальные .env файлы можно коммитить (не содержат секретов)
# .env - только настройки проекта
# .env_php - только версии
# .env_redis - только хост и порт
# .env_push_pub - только порт и режим
# .env_push_sub - только порт и режим
# .env_ssl - данные для сертификатов (можно коммитить, но по желанию можно скрыть)

# Директория с файлами сайта (если используется bind mount)
www/*
!www/.gitignore
!www/README.md
www-bindfs/

# Временные файлы
*.log
*.tmp
*.swp
*~

# IDE файлы
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS файлы
.DS_Store
Thumbs.db

